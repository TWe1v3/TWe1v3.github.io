---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '能力沉淀、个人思考、自动化实验与安全研究。'
} = Astro.props;
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 64 64'%3E%3Crect width='64' height='64' rx='16' fill='%23181d21'/%3E%3Cpath d='M18 18h28v6H35v22h-6V24H18z' fill='%23f6f1e6'/%3E%3Ccircle cx='47' cy='18' r='5' fill='%23c54f34'/%3E%3C/svg%3E"
    />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f4eee2;
        --bg-strong: #f9f4ea;
        --paper: rgba(255, 251, 244, 0.9);
        --paper-strong: #fffaf2;
        --paper-ink: #f2ead8;
        --ink: #1c1c1c;
        --ink-soft: #4e4c47;
        --ink-muted: #736c60;
        --line: rgba(28, 28, 28, 0.1);
        --line-strong: rgba(28, 28, 28, 0.18);
        --accent: #c45532;
        --accent-strong: #8b2f18;
        --accent-2: #1e5f96;
        --accent-3: #0f8068;
        --shadow: 0 24px 80px rgba(71, 49, 24, 0.08);
        --shadow-soft: 0 16px 42px rgba(71, 49, 24, 0.06);
        --radius-xl: 34px;
        --radius-lg: 24px;
        --radius-md: 18px;
        --page-width: 1200px;
        --reading-width: 760px;
        --serif: "Iowan Old Style", "Baskerville", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        --sans: "Avenir Next", "PingFang SC", "Hiragino Sans GB", "Segoe UI", sans-serif;
        --mono: "IBM Plex Mono", "SFMono-Regular", "SF Mono", Menlo, Consolas, monospace;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        min-height: 100vh;
        font-family: var(--sans);
        background:
          radial-gradient(circle at top left, rgba(196, 85, 50, 0.18), transparent 28%),
          radial-gradient(circle at 82% 12%, rgba(30, 95, 150, 0.16), transparent 24%),
          linear-gradient(180deg, #fbf7ef 0%, #f4eee2 52%, #efe6d8 100%);
        color: var(--ink);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        position: relative;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(rgba(28, 28, 28, 0.04) 1px, transparent 1px),
          linear-gradient(90deg, rgba(28, 28, 28, 0.04) 1px, transparent 1px);
        background-size: 28px 28px;
        mask-image: radial-gradient(circle at center, black 38%, transparent 100%);
        opacity: 0.35;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at center, transparent 52%, rgba(87, 58, 24, 0.08)),
          linear-gradient(180deg, rgba(255,255,255,0.16), rgba(124, 87, 45, 0.03));
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        display: block;
        max-width: 100%;
      }

      ::selection {
        background: rgba(196, 85, 50, 0.18);
        color: #1a1a1a;
      }

      .page-shell {
        width: min(calc(100% - 40px), var(--page-width));
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .page-shell--wide {
        padding-bottom: 56px;
      }

      .site-header {
        display: flex;
        justify-content: space-between;
        align-items: flex-end;
        gap: 20px;
        padding: 28px 0 22px;
        border-bottom: 1px solid var(--line-strong);
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 14px;
      }

      .brand-mark {
        width: 14px;
        height: 14px;
        border-radius: 4px;
        background:
          linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow:
          0 0 0 8px rgba(196, 85, 50, 0.08),
          0 8px 26px rgba(30, 95, 150, 0.18);
        transform: rotate(12deg);
      }

      .brand-copy {
        display: flex;
        flex-direction: column;
        gap: 3px;
      }

      .brand-copy strong {
        font-size: 15px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
      }

      .brand-copy small {
        color: var(--ink-muted);
        font-size: 11px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .site-header__meta {
        display: flex;
        flex-direction: column;
        gap: 10px;
      }

      .site-header__note {
        margin: 0;
        max-width: 34rem;
        color: var(--ink-muted);
        font-size: 13px;
        line-height: 1.8;
      }

      .nav-links {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 12px;
        align-items: center;
      }

      .site-nav {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        gap: 10px;
        align-items: center;
      }

      .site-nav__link,
      .site-nav__ghost {
        display: inline-flex;
        align-items: center;
        min-height: 38px;
        padding: 0 14px;
        border-radius: 999px;
        font-size: 12px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
        border: 1px solid var(--line);
        transition:
          background-color 180ms ease,
          color 180ms ease,
          border-color 180ms ease,
          transform 180ms ease;
      }

      .site-nav__link:hover,
      .site-nav__ghost:hover,
      .site-nav__link.is-active {
        border-color: rgba(196, 85, 50, 0.24);
        background: rgba(196, 85, 50, 0.08);
        color: var(--accent-strong);
        transform: translateY(-1px);
      }

      .site-nav__ghost {
        background: rgba(30, 95, 150, 0.07);
      }

      .hero,
      .page-hero,
      .article-hero,
      .panel,
      .story-card,
      .lead-story,
      .archive-group,
      .site-footer,
      .prose-card,
      .note-card,
      .track-card,
      .metric-card,
      .timeline-card,
      .cluster-card,
      .compact-card,
      .manifesto-card {
        background: linear-gradient(180deg, rgba(255, 251, 244, 0.95), rgba(252, 247, 238, 0.88));
        border: 1px solid var(--line);
        box-shadow: var(--shadow-soft);
      }

      .hero,
      .page-hero,
      .article-hero,
      .site-footer,
      .prose-card,
      .manifesto-card {
        border-radius: var(--radius-xl);
      }

      .panel,
      .story-card,
      .lead-story,
      .archive-group,
      .note-card,
      .track-card,
      .metric-card,
      .timeline-card,
      .cluster-card,
      .compact-card {
        border-radius: var(--radius-lg);
      }

      .hero {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(280px, 0.7fr);
        gap: 22px;
        padding: 30px;
        margin-top: 22px;
        align-items: stretch;
        overflow: hidden;
        position: relative;
      }

      .hero::before,
      .page-hero::before,
      .article-hero::before {
        content: "";
        position: absolute;
        inset: 0;
        pointer-events: none;
        background:
          radial-gradient(circle at top left, rgba(196, 85, 50, 0.14), transparent 34%),
          radial-gradient(circle at right 18%, rgba(30, 95, 150, 0.15), transparent 24%);
      }

      .hero-copy,
      .hero-board {
        position: relative;
        z-index: 1;
      }

      .eyebrow,
      .card-eyebrow,
      .story-meta,
      .metric-label {
        color: var(--accent-strong);
        font-size: 11px;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .hero-title,
      .section-title,
      .page-title,
      .article-title {
        margin: 14px 0 0;
        font-family: var(--serif);
        font-weight: 700;
        letter-spacing: -0.045em;
        line-height: 1.02;
      }

      .hero-title,
      .page-title,
      .article-title {
        width: 100%;
        max-width: none;
        text-wrap: pretty;
      }

      .section-title {
        text-wrap: balance;
      }

      .hero-title {
        font-size: clamp(42px, 6vw, 76px);
      }

      .page-title {
        font-size: clamp(34px, 4.8vw, 56px);
      }

      .article-title {
        font-size: clamp(34px, 5vw, 60px);
      }

      .hero-lede,
      .page-lede,
      .article-lede,
      .section-copy,
      .card-copy,
      .panel p,
      .manifesto-card p {
        color: var(--ink-soft);
        line-height: 1.85;
      }

      .hero-lede,
      .page-lede,
      .article-lede {
        margin: 22px 0 0;
        max-width: 44rem;
        font-size: 18px;
      }

      .chip-row,
      .tag-row,
      .metric-row {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        margin-top: 22px;
      }

      .chip,
      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 32px;
        padding: 0 12px;
        border-radius: 999px;
        border: 1px solid rgba(196, 85, 50, 0.18);
        background: rgba(196, 85, 50, 0.08);
        color: var(--accent-strong);
        font-size: 11px;
        letter-spacing: 0.1em;
        text-transform: uppercase;
      }

      .hero-board {
        display: grid;
        gap: 14px;
      }

      .note-card,
      .metric-card,
      .track-card,
      .compact-card,
      .timeline-card,
      .archive-group,
      .panel,
      .story-card,
      .lead-story,
      .manifesto-card {
        padding: 22px;
      }

      .note-card p,
      .metric-card p,
      .track-card p,
      .compact-card p,
      .timeline-card p,
      .archive-group p,
      .story-card p,
      .lead-story p {
        margin: 12px 0 0;
        color: var(--ink-soft);
        line-height: 1.8;
      }

      .note-card strong {
        display: block;
        font-size: 17px;
        letter-spacing: -0.02em;
      }

      .section-block {
        padding-top: 24px;
      }

      .section-heading {
        display: grid;
        grid-template-columns: minmax(0, 1fr) minmax(260px, 0.65fr);
        gap: 18px;
        align-items: end;
        margin-bottom: 18px;
      }

      .section-title {
        font-size: clamp(32px, 3.8vw, 52px);
      }

      .metric-grid,
      .track-grid,
      .story-grid,
      .cluster-grid,
      .archive-grid,
      .signal-grid,
      .page-grid,
      .split-grid {
        display: grid;
        gap: 18px;
      }

      .metric-grid {
        grid-template-columns: repeat(4, minmax(0, 1fr));
        margin-top: 18px;
      }

      .track-grid,
      .signal-grid,
      .story-grid {
        grid-template-columns: repeat(3, minmax(0, 1fr));
      }

      .page-grid,
      .archive-grid {
        grid-template-columns: repeat(2, minmax(0, 1fr));
      }

      .split-grid {
        grid-template-columns: minmax(0, 1.15fr) minmax(280px, 0.85fr);
      }

      .feature-story-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.1fr) minmax(280px, 0.9fr);
        gap: 18px;
      }

      .story-stack {
        display: grid;
        gap: 18px;
      }

      .story-card,
      .lead-story,
      .track-card,
      .compact-card,
      .timeline-card,
      .archive-entry {
        position: relative;
        overflow: hidden;
        transition:
          transform 200ms ease,
          box-shadow 200ms ease,
          border-color 200ms ease;
      }

      .story-card:hover,
      .lead-story:hover,
      .track-card:hover,
      .compact-card:hover,
      .archive-entry:hover {
        transform: translateY(-3px);
        box-shadow: var(--shadow);
        border-color: rgba(196, 85, 50, 0.22);
      }

      .story-card::before,
      .lead-story::before,
      .track-card::before,
      .compact-card::before,
      .timeline-card::before,
      .page-hero::after,
      .hero::after {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 160px;
        height: 160px;
        background: radial-gradient(circle, rgba(196, 85, 50, 0.12), transparent 72%);
        pointer-events: none;
      }

      .story-card > *,
      .lead-story > *,
      .track-card > *,
      .compact-card > *,
      .timeline-card > *,
      .page-hero > *,
      .hero > * {
        position: relative;
        z-index: 1;
      }

      .story-title,
      .track-card h3,
      .compact-card h3,
      .timeline-card h3,
      .archive-entry h3,
      .panel h3 {
        margin: 10px 0 0;
        font-family: var(--serif);
        font-size: 20px;
        letter-spacing: -0.035em;
        line-height: 1.08;
      }

      .lead-story .story-title,
      .lead-story h2 {
        font-size: clamp(30px, 3.6vw, 48px);
      }

      .story-link,
      .inline-link {
        display: inline-flex;
        gap: 8px;
        margin-top: 18px;
        color: var(--accent-strong);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        font-weight: 700;
      }

      .metric-card strong {
        display: block;
        margin-top: 14px;
        font-family: var(--serif);
        font-size: clamp(34px, 4vw, 52px);
        letter-spacing: -0.05em;
      }

      .metric-card p {
        margin-top: 10px;
      }

      .story-meta,
      .archive-month,
      .timeline-meta {
        color: var(--ink-muted);
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
      }

      .archive-group {
        display: grid;
        gap: 12px;
      }

      .archive-entry {
        display: grid;
        gap: 8px;
        padding: 16px 0 0;
        border-top: 1px solid var(--line);
      }

      .archive-entry:first-of-type {
        padding-top: 0;
        border-top: none;
      }

      .page-hero,
      .article-hero,
      .prose-card,
      .manifesto-card {
        margin-top: 22px;
        padding: 30px;
        position: relative;
        overflow: hidden;
      }

      .article-shell {
        width: min(calc(100% - 40px), 980px);
        margin: 0 auto;
        position: relative;
        z-index: 1;
        padding-bottom: 48px;
      }

      .back-link {
        display: inline-flex;
        gap: 10px;
        margin-top: 18px;
        color: var(--ink-muted);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 10px 16px;
        color: var(--ink-muted);
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .prose {
        width: min(100%, var(--reading-width));
        margin: 0 auto;
        font-size: 18px;
        line-height: 1.95;
        color: var(--ink-soft);
      }

      .prose > *:first-child {
        margin-top: 0;
      }

      .prose h2,
      .prose h3 {
        margin-top: 2.4em;
        margin-bottom: 0.7em;
        font-family: var(--serif);
        letter-spacing: -0.04em;
        line-height: 1.14;
        color: var(--ink);
      }

      .prose h2 {
        font-size: 34px;
      }

      .prose h3 {
        font-size: 26px;
      }

      .prose p,
      .prose li {
        color: var(--ink-soft);
      }

      .prose ul,
      .prose ol {
        padding-left: 1.35em;
      }

      .prose a {
        color: var(--accent-2);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.2em;
      }

      .prose strong {
        color: var(--ink);
      }

      .prose blockquote {
        margin: 2em 0;
        padding: 0 0 0 20px;
        border-left: 3px solid var(--accent);
        color: var(--ink);
        font-family: var(--serif);
        font-size: 1.06em;
      }

      .prose code {
        font-family: var(--mono);
        padding: 0.16em 0.42em;
        border: 1px solid rgba(30, 95, 150, 0.2);
        border-radius: 8px;
        background: rgba(30, 95, 150, 0.08);
        font-size: 0.86em;
      }

      .prose pre {
        padding: 18px 20px;
        border-radius: 18px;
        overflow-x: auto;
        border: 1px solid var(--line);
        background: #1e2128;
        color: #f3efe5;
        box-shadow: inset 0 1px 0 rgba(255, 255, 255, 0.04);
      }

      .prose pre code {
        padding: 0;
        background: transparent;
        border: none;
      }

      .prose hr {
        border: none;
        border-top: 1px solid var(--line);
        margin: 2.4em 0;
      }

      .prose table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95em;
      }

      .prose th,
      .prose td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        text-align: left;
      }

      .prose th {
        color: var(--ink);
        font-weight: 600;
      }

      .site-footer {
        display: flex;
        justify-content: space-between;
        gap: 16px;
        align-items: center;
        margin-top: 24px;
        padding: 20px 24px;
      }

      .site-footer__copy {
        display: flex;
        flex-wrap: wrap;
        gap: 10px;
        align-items: center;
      }

      .site-footer__copy strong,
      .site-footer__links a {
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .site-footer__copy span {
        color: var(--ink-muted);
        font-size: 14px;
      }

      .site-footer__links {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
      }

      .site-footer__links a {
        color: var(--accent-strong);
      }

      .animate-rise {
        animation: rise 560ms ease both;
      }

      @keyframes rise {
        from {
          opacity: 0;
          transform: translateY(16px);
        }
        to {
          opacity: 1;
          transform: translateY(0);
        }
      }

      @media (max-width: 960px) {
        .metric-grid,
        .track-grid,
        .story-grid,
        .signal-grid,
        .page-grid,
        .split-grid,
        .feature-story-grid,
        .section-heading,
        .hero {
          grid-template-columns: 1fr;
        }
      }

      @media (max-width: 640px) {
        .page-shell,
        .article-shell {
          width: min(calc(100% - 24px), var(--page-width));
        }

        .site-header,
        .site-footer {
          flex-direction: column;
          align-items: flex-start;
        }

        .hero,
        .page-hero,
        .article-hero,
        .prose-card,
        .manifesto-card,
        .story-card,
        .lead-story,
        .track-card,
        .metric-card,
        .compact-card,
        .timeline-card,
        .archive-group,
        .site-footer {
          padding: 20px;
        }

        .hero-title,
        .page-title,
        .article-title {
          font-size: 42px;
        }

        .prose {
          font-size: 17px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
