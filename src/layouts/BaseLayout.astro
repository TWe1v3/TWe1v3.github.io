---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '能力沉淀、个人思考、自动化实验与安全研究。'
} = Astro.props;
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f6f1e8;
        --bg-soft: #fbf8f3;
        --paper: rgba(255, 252, 247, 0.82);
        --paper-strong: rgba(255, 252, 247, 0.96);
        --line: rgba(24, 27, 35, 0.12);
        --line-strong: rgba(24, 27, 35, 0.2);
        --text: #181b23;
        --muted: #697180;
        --muted-strong: #4e5563;
        --accent: #4458d8;
        --accent-soft: rgba(68, 88, 216, 0.1);
        --shadow: 0 24px 60px rgba(33, 31, 24, 0.08);
        --radius-xl: 28px;
        --radius-lg: 22px;
        --radius-md: 16px;
        --content-width: 1160px;
        --reading-width: 760px;
      }

      * {
        box-sizing: border-box;
      }

      html {
        scroll-behavior: smooth;
      }

      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        color: var(--text);
        background:
          radial-gradient(circle at top left, rgba(113, 129, 255, 0.12), transparent 32%),
          radial-gradient(circle at top right, rgba(214, 165, 90, 0.16), transparent 28%),
          linear-gradient(180deg, #f7f3eb 0%, #f3eee6 100%);
        min-height: 100vh;
      }

      a {
        color: inherit;
        text-decoration: none;
      }

      img {
        max-width: 100%;
        display: block;
      }

      .shell {
        width: min(calc(100% - 40px), var(--content-width));
        margin: 0 auto;
      }

      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 24px 0 10px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .brand-mark {
        width: 12px;
        height: 12px;
        border-radius: 999px;
        background: linear-gradient(135deg, #1d2438, #5568e8 80%);
        box-shadow: 0 0 0 6px rgba(68, 88, 216, 0.08);
      }

      .nav-note {
        font-size: 13px;
        color: var(--muted);
      }

      .hero {
        position: relative;
        overflow: hidden;
        padding: 40px;
        border: 1px solid rgba(255, 255, 255, 0.65);
        border-radius: var(--radius-xl);
        background: linear-gradient(180deg, rgba(255, 252, 247, 0.84), rgba(255, 250, 244, 0.72));
        box-shadow: var(--shadow);
        backdrop-filter: blur(18px);
      }

      .hero::after {
        content: '';
        position: absolute;
        inset: auto -120px -160px auto;
        width: 320px;
        height: 320px;
        border-radius: 50%;
        background: radial-gradient(circle, rgba(68, 88, 216, 0.14), transparent 70%);
        pointer-events: none;
      }

      .eyebrow {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        padding: 8px 12px;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--muted-strong);
        background: rgba(255, 255, 255, 0.48);
        font-size: 13px;
        letter-spacing: 0.04em;
      }

      .eyebrow::before {
        content: '';
        width: 7px;
        height: 7px;
        border-radius: 999px;
        background: var(--accent);
      }

      .hero-grid {
        display: grid;
        gap: 28px;
        grid-template-columns: minmax(0, 1.6fr) minmax(280px, 0.9fr);
        align-items: end;
        margin-top: 22px;
      }

      .hero h1,
      .article-header h1 {
        margin: 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        letter-spacing: -0.03em;
        line-height: 1.02;
      }

      .hero h1 {
        font-size: clamp(48px, 8vw, 82px);
        max-width: 10ch;
      }

      .hero p {
        margin: 18px 0 0;
        max-width: 62ch;
        font-size: 18px;
        line-height: 1.9;
        color: var(--muted-strong);
      }

      .hero-side {
        display: grid;
        gap: 14px;
      }

      .note-card,
      .article-card,
      .post-card {
        border: 1px solid var(--line);
        border-radius: var(--radius-lg);
        background: var(--paper);
        box-shadow: var(--shadow);
        backdrop-filter: blur(16px);
      }

      .note-card {
        padding: 18px 20px;
      }

      .note-label {
        margin: 0 0 8px;
        color: var(--muted);
        font-size: 12px;
        text-transform: uppercase;
        letter-spacing: 0.08em;
      }

      .note-card p {
        margin: 0;
        color: var(--muted-strong);
        font-size: 15px;
        line-height: 1.75;
      }

      .section {
        margin-top: 42px;
      }

      .section-head {
        display: flex;
        justify-content: space-between;
        align-items: end;
        gap: 20px;
        margin-bottom: 18px;
      }

      .section-title {
        margin: 0;
        font-size: 24px;
        letter-spacing: -0.02em;
      }

      .section-copy {
        margin: 6px 0 0;
        color: var(--muted);
        max-width: 56ch;
        line-height: 1.8;
      }

      .post-grid {
        display: grid;
        gap: 18px;
      }

      .post-card {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 20px;
        padding: 24px;
        transition: transform 180ms ease, border-color 180ms ease, box-shadow 180ms ease;
      }

      .post-card:hover {
        transform: translateY(-2px);
        border-color: rgba(68, 88, 216, 0.28);
        box-shadow: 0 26px 70px rgba(33, 31, 24, 0.12);
      }

      .post-meta {
        margin: 0 0 12px;
        color: var(--muted);
        font-size: 13px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
      }

      .post-card h3 {
        margin: 0;
        font-size: 26px;
        line-height: 1.25;
        letter-spacing: -0.03em;
      }

      .post-card p {
        margin: 12px 0 0;
        color: var(--muted-strong);
        line-height: 1.85;
      }

      .post-arrow {
        align-self: start;
        color: var(--muted);
        font-size: 20px;
      }

      .pill-row,
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
      }

      .pill,
      .tag {
        display: inline-flex;
        align-items: center;
        padding: 6px 10px;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.7);
        border: 1px solid var(--line);
        color: var(--muted-strong);
        font-size: 12px;
        letter-spacing: 0.03em;
      }

      .about-grid {
        display: grid;
        grid-template-columns: minmax(0, 1.2fr) minmax(280px, 0.8fr);
        gap: 18px;
      }

      .about-card {
        padding: 26px;
      }

      .about-card p,
      .about-card li {
        color: var(--muted-strong);
        line-height: 1.9;
      }

      .about-card ul {
        margin: 14px 0 0;
        padding-left: 18px;
      }

      .site-footer {
        padding: 24px 0 52px;
        color: var(--muted);
        font-size: 14px;
      }

      .article-shell {
        width: min(calc(100% - 40px), 920px);
        margin: 0 auto;
      }

      .article-header {
        margin-top: 18px;
        padding: 32px;
        border: 1px solid rgba(255, 255, 255, 0.65);
        border-radius: var(--radius-xl);
        background: linear-gradient(180deg, rgba(255, 252, 247, 0.9), rgba(255, 248, 239, 0.76));
        box-shadow: var(--shadow);
      }

      .article-header h1 {
        font-size: clamp(36px, 5.5vw, 62px);
        max-width: 12ch;
      }

      .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        margin-bottom: 18px;
        color: var(--muted);
        font-size: 13px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
      }

      .article-desc {
        margin: 18px 0 0;
        max-width: 42rem;
        font-size: 18px;
        line-height: 1.85;
        color: var(--muted-strong);
      }

      .article-card {
        margin-top: 18px;
        padding: 40px 42px 46px;
        background: var(--paper-strong);
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        color: var(--muted);
        font-size: 14px;
      }

      .prose {
        width: min(100%, var(--reading-width));
        margin: 0 auto;
        font-size: 18px;
        line-height: 1.95;
      }

      .prose > *:first-child {
        margin-top: 0;
      }

      .prose h2,
      .prose h3 {
        margin-top: 2.4em;
        margin-bottom: 0.75em;
        line-height: 1.25;
        letter-spacing: -0.03em;
      }

      .prose h2 {
        font-size: 31px;
      }

      .prose h3 {
        font-size: 24px;
      }

      .prose p,
      .prose li {
        color: rgba(24, 27, 35, 0.88);
      }

      .prose ul,
      .prose ol {
        padding-left: 1.3em;
      }

      .prose blockquote {
        margin: 2em 0;
        padding: 18px 20px;
        border-left: 3px solid var(--accent);
        background: var(--accent-soft);
        border-radius: 0 16px 16px 0;
        color: #283049;
      }

      .prose code {
        font-family: "SFMono-Regular", ui-monospace, SFMono-Regular, Menlo, monospace;
        padding: 0.15em 0.4em;
        border-radius: 8px;
        background: rgba(35, 39, 48, 0.08);
        font-size: 0.88em;
      }

      .prose strong {
        color: #111318;
      }

      @media (max-width: 900px) {
        .hero,
        .article-header,
        .article-card {
          padding: 28px;
        }

        .hero-grid,
        .about-grid,
        .post-card {
          grid-template-columns: 1fr;
        }

        .post-card {
          gap: 14px;
        }
      }

      @media (max-width: 640px) {
        .shell,
        .article-shell {
          width: min(calc(100% - 28px), var(--content-width));
        }

        .site-nav {
          flex-direction: column;
          align-items: flex-start;
          gap: 8px;
        }

        .hero,
        .article-header,
        .article-card,
        .about-card,
        .post-card {
          padding: 22px;
        }

        .hero h1 {
          font-size: 42px;
        }

        .post-card h3 {
          font-size: 22px;
        }

        .prose {
          font-size: 17px;
        }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
