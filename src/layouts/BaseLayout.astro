---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '能力沉淀、个人思考、自动化实验与安全研究。'
} = Astro.props;
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: light;
        --bg: #f3efe6;
        --paper: #faf7f1;
        --line: rgba(25, 28, 34, 0.12);
        --line-strong: rgba(25, 28, 34, 0.22);
        --text: #17191f;
        --muted: #66707f;
        --soft: #8b93a1;
        --accent: #2d5bd1;
        --accent-soft: rgba(45, 91, 209, 0.08);
        --shadow: 0 18px 48px rgba(28, 27, 23, 0.05);
        --page-width: 1100px;
        --article-width: 760px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        font-family: Inter, ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background: var(--bg);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
      }
      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }

      .shell {
        width: min(calc(100% - 40px), var(--page-width));
        margin: 0 auto;
      }

      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 28px 0 18px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        font-size: 15px;
        font-weight: 700;
        letter-spacing: 0.02em;
      }

      .brand-mark {
        width: 10px;
        height: 10px;
        border-radius: 999px;
        background: var(--text);
      }

      .nav-note {
        color: var(--muted);
        font-size: 13px;
      }

      .divider {
        height: 1px;
        background: var(--line);
      }

      .home-intro {
        display: grid;
        grid-template-columns: minmax(0, 1.3fr) minmax(240px, 0.7fr);
        gap: 40px;
        padding: 42px 0 32px;
      }

      .kicker,
      .section-kicker,
      .meta-kicker {
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .home-intro h1,
      .article-header h1 {
        margin: 10px 0 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        font-weight: 700;
        letter-spacing: -0.04em;
        line-height: 1.04;
      }

      .home-intro h1 {
        max-width: 10ch;
        font-size: clamp(44px, 7vw, 78px);
      }

      .lede {
        margin: 22px 0 0;
        max-width: 42rem;
        color: rgba(23, 25, 31, 0.84);
        font-size: 18px;
        line-height: 1.95;
      }

      .intro-side {
        align-self: end;
        display: grid;
        gap: 20px;
      }

      .intro-note {
        padding-top: 18px;
        border-top: 1px solid var(--line);
      }

      .intro-note p {
        margin: 8px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.9;
      }

      .section {
        padding: 30px 0 14px;
      }

      .section-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: end;
        margin-bottom: 20px;
      }

      .section-head h2 {
        margin: 8px 0 0;
        font-size: 28px;
        letter-spacing: -0.03em;
      }

      .section-copy {
        margin: 0;
        max-width: 46rem;
        color: var(--muted);
        line-height: 1.85;
      }

      .post-list {
        border-top: 1px solid var(--line);
      }

      .post-row {
        display: grid;
        grid-template-columns: 140px minmax(0, 1fr) auto;
        gap: 24px;
        padding: 26px 0;
        border-bottom: 1px solid var(--line);
        transition: background-color 160ms ease, padding-left 160ms ease;
      }

      .post-row:hover {
        background: rgba(255, 255, 255, 0.22);
        padding-left: 10px;
      }

      .post-date {
        color: var(--soft);
        font-size: 13px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        padding-top: 4px;
      }

      .post-row h3 {
        margin: 0;
        font-size: 28px;
        letter-spacing: -0.035em;
        line-height: 1.2;
      }

      .post-row p {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.85;
      }

      .pill-row,
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 14px;
      }

      .pill,
      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 0 10px;
        border: 1px solid var(--line);
        border-radius: 999px;
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.04em;
        text-transform: uppercase;
        background: rgba(255, 255, 255, 0.35);
      }

      .post-link-mark {
        color: var(--soft);
        font-size: 18px;
        padding-top: 4px;
      }

      .about-block {
        max-width: 58rem;
        padding: 24px 0 40px;
      }

      .about-block p {
        margin: 10px 0 0;
        color: var(--muted);
        line-height: 1.95;
      }

      .site-footer {
        padding: 28px 0 56px;
        border-top: 1px solid var(--line);
        color: var(--soft);
        font-size: 13px;
      }

      .article-shell {
        width: min(calc(100% - 40px), 920px);
        margin: 0 auto;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 8px;
        color: var(--muted);
        font-size: 14px;
      }

      .article-header {
        padding: 40px 0 28px;
        border-bottom: 1px solid var(--line);
      }

      .article-header h1 {
        max-width: 15ch;
        font-size: clamp(36px, 5vw, 58px);
        text-wrap: balance;
      }

      .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        color: var(--soft);
        font-size: 12px;
        letter-spacing: 0.12em;
        text-transform: uppercase;
      }

      .article-desc {
        margin: 18px 0 0;
        max-width: 43rem;
        color: rgba(23, 25, 31, 0.82);
        font-size: 19px;
        line-height: 1.9;
      }

      .article-main {
        padding: 34px 0 52px;
      }

      .prose {
        width: min(100%, var(--article-width));
        font-size: 19px;
        line-height: 2;
      }

      .prose > *:first-child { margin-top: 0; }
      .prose h2,
      .prose h3 {
        margin-top: 2.5em;
        margin-bottom: 0.7em;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        letter-spacing: -0.03em;
        line-height: 1.2;
      }
      .prose h2 { font-size: 34px; }
      .prose h3 { font-size: 26px; }
      .prose p,
      .prose li { color: rgba(23, 25, 31, 0.88); }
      .prose ul,
      .prose ol { padding-left: 1.35em; }
      .prose a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.16em;
      }
      .prose strong { color: var(--text); }
      .prose blockquote {
        margin: 2em 0;
        padding: 0 0 0 18px;
        border-left: 2px solid var(--line-strong);
        color: #313845;
      }
      .prose code {
        font-family: "SFMono-Regular", ui-monospace, Menlo, monospace;
        padding: 0.14em 0.4em;
        border-radius: 6px;
        background: rgba(23, 25, 31, 0.06);
        font-size: 0.88em;
      }

      @media (max-width: 840px) {
        .home-intro,
        .section-head,
        .post-row {
          grid-template-columns: 1fr;
        }
        .post-row { gap: 12px; }
      }

      @media (max-width: 640px) {
        .shell,
        .article-shell {
          width: min(calc(100% - 28px), var(--page-width));
        }
        .site-nav {
          flex-direction: column;
          align-items: flex-start;
        }
        .home-intro { padding-top: 30px; }
        .home-intro h1 { font-size: 42px; }
        .post-row h3 { font-size: 23px; }
        .prose { font-size: 18px; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
