---
interface Props {
  title: string;
  description?: string;
}

const {
  title,
  description = '能力沉淀、个人思考、自动化实验与安全研究。'
} = Astro.props;
---
<html lang="zh-CN">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style is:global>
      :root {
        color-scheme: dark;
        --bg: #09111f;
        --bg-elevated: rgba(14, 23, 40, 0.72);
        --panel: rgba(10, 19, 35, 0.9);
        --panel-strong: rgba(14, 25, 45, 0.96);
        --paper: #dbe8ff;
        --text: #edf4ff;
        --text-dim: rgba(237, 244, 255, 0.88);
        --muted: #92a4c4;
        --soft: #667a9d;
        --line: rgba(146, 164, 196, 0.16);
        --line-strong: rgba(146, 164, 196, 0.32);
        --accent: #91f2c3;
        --accent-2: #6fa8ff;
        --accent-soft: rgba(145, 242, 195, 0.14);
        --glow: rgba(111, 168, 255, 0.24);
        --shadow: 0 30px 90px rgba(2, 8, 18, 0.45);
        --page-width: 1180px;
        --article-width: 760px;
        --radius: 24px;
      }

      * { box-sizing: border-box; }
      html { scroll-behavior: smooth; }
      body {
        margin: 0;
        min-height: 100vh;
        font-family: "IBM Plex Sans", "Inter", ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif;
        background:
          radial-gradient(circle at top left, rgba(111, 168, 255, 0.2), transparent 32%),
          radial-gradient(circle at 85% 18%, rgba(145, 242, 195, 0.12), transparent 26%),
          linear-gradient(180deg, #0a1220 0%, #08101d 48%, #070d18 100%);
        color: var(--text);
        -webkit-font-smoothing: antialiased;
        text-rendering: optimizeLegibility;
        position: relative;
      }

      body::before {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background:
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 24px 24px;
        mask-image: radial-gradient(circle at center, black 38%, transparent 100%);
        opacity: 0.18;
      }

      body::after {
        content: "";
        position: fixed;
        inset: 0;
        pointer-events: none;
        background: radial-gradient(circle at center, transparent, rgba(3, 8, 15, 0.38));
      }

      a { color: inherit; text-decoration: none; }
      img { display: block; max-width: 100%; }
      ::selection {
        background: rgba(145, 242, 195, 0.24);
        color: #f5fffb;
      }

      .shell {
        width: min(calc(100% - 40px), var(--page-width));
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .site-nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        padding: 30px 0 18px;
      }

      .brand {
        display: inline-flex;
        align-items: center;
        gap: 12px;
        font-size: 13px;
        font-weight: 700;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .brand-mark {
        width: 11px;
        height: 11px;
        border-radius: 999px;
        background: linear-gradient(135deg, var(--accent), var(--accent-2));
        box-shadow: 0 0 0 6px rgba(145, 242, 195, 0.08);
      }

      .nav-note {
        color: var(--muted);
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .divider {
        height: 1px;
        background: linear-gradient(90deg, transparent, var(--line-strong), transparent);
      }

      .home-intro {
        display: grid;
        grid-template-columns: minmax(0, 1.25fr) minmax(280px, 0.75fr);
        gap: 28px;
        padding: 34px 0 20px;
        align-items: stretch;
      }

      .hero-panel,
      .intro-side,
      .post-list,
      .about-block,
      .article-header,
      .article-main,
      .site-footer {
        background: linear-gradient(180deg, rgba(13, 22, 39, 0.88), rgba(9, 16, 28, 0.94));
        border: 1px solid var(--line);
        box-shadow: var(--shadow);
        backdrop-filter: blur(12px);
      }

      .hero-panel,
      .article-header,
      .article-main,
      .site-footer,
      .about-block {
        border-radius: var(--radius);
      }

      .hero-panel {
        padding: 34px 30px 30px;
        position: relative;
        overflow: hidden;
      }

      .hero-panel::before,
      .article-header::before {
        content: "";
        position: absolute;
        inset: 0 auto auto 0;
        width: 220px;
        height: 220px;
        background: radial-gradient(circle, rgba(111, 168, 255, 0.16), transparent 70%);
        pointer-events: none;
      }

      .hero-panel::after {
        content: "research log / public operator notebook";
        position: absolute;
        right: 18px;
        top: 18px;
        color: rgba(146, 164, 196, 0.18);
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .kicker,
      .section-kicker,
      .meta-kicker {
        color: var(--accent);
        font-size: 11px;
        letter-spacing: 0.22em;
        text-transform: uppercase;
      }

      .home-intro h1,
      .article-header h1 {
        margin: 12px 0 0;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        font-weight: 700;
        letter-spacing: -0.05em;
        line-height: 0.98;
        text-wrap: balance;
      }

      .home-intro h1 {
        max-width: 11ch;
        font-size: clamp(48px, 7vw, 84px);
      }

      .lede {
        margin: 24px 0 0;
        max-width: 44rem;
        color: var(--text-dim);
        font-size: 18px;
        line-height: 1.95;
      }

      .intro-side {
        display: grid;
        gap: 14px;
        padding: 14px;
        border-radius: var(--radius);
      }

      .intro-note {
        padding: 18px 18px 16px;
        border-radius: 18px;
        border: 1px solid var(--line);
        background: linear-gradient(180deg, rgba(18, 29, 50, 0.72), rgba(10, 18, 30, 0.88));
      }

      .intro-note p {
        margin: 10px 0 0;
        color: var(--muted);
        font-size: 15px;
        line-height: 1.85;
      }

      .section {
        padding: 22px 0 14px;
      }

      .section-head {
        display: grid;
        grid-template-columns: minmax(0, 1fr) auto;
        gap: 16px;
        align-items: end;
        margin-bottom: 20px;
      }

      .section-head h2 {
        margin: 10px 0 0;
        font-size: clamp(28px, 3.4vw, 40px);
        letter-spacing: -0.04em;
      }

      .section-copy {
        margin: 0;
        max-width: 42rem;
        color: var(--muted);
        line-height: 1.85;
      }

      .post-list {
        border-radius: var(--radius);
        overflow: hidden;
      }

      .post-row {
        display: grid;
        grid-template-columns: 132px minmax(0, 1fr) auto;
        gap: 24px;
        padding: 24px 26px;
        border-bottom: 1px solid var(--line);
        position: relative;
        transition: transform 180ms ease, background-color 180ms ease, border-color 180ms ease;
      }

      .post-row:last-child { border-bottom: none; }

      .post-row::before {
        content: "";
        position: absolute;
        inset: 0;
        background: linear-gradient(90deg, rgba(145, 242, 195, 0.05), transparent 28%, transparent 70%, rgba(111, 168, 255, 0.06));
        opacity: 0;
        transition: opacity 180ms ease;
        pointer-events: none;
      }

      .post-row:hover {
        transform: translateY(-2px);
        background: rgba(15, 27, 45, 0.74);
        border-color: var(--line-strong);
      }

      .post-row:hover::before { opacity: 1; }

      .post-date {
        color: var(--soft);
        font-size: 12px;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        padding-top: 6px;
      }

      .post-row h3 {
        margin: 0;
        font-size: clamp(24px, 3vw, 34px);
        letter-spacing: -0.04em;
        line-height: 1.16;
      }

      .post-row p {
        margin: 12px 0 0;
        color: var(--muted);
        line-height: 1.82;
      }

      .pill-row,
      .tags {
        display: flex;
        flex-wrap: wrap;
        gap: 8px;
        margin-top: 16px;
      }

      .pill,
      .tag {
        display: inline-flex;
        align-items: center;
        min-height: 28px;
        padding: 0 11px;
        border: 1px solid rgba(145, 242, 195, 0.2);
        border-radius: 999px;
        color: #b9f8da;
        font-size: 11px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
        background: rgba(145, 242, 195, 0.08);
      }

      .post-link-mark {
        color: var(--accent);
        font-size: 20px;
        padding-top: 4px;
      }

      .about-block {
        max-width: 64rem;
        padding: 26px 26px 30px;
      }

      .about-block p {
        margin: 12px 0 0;
        color: var(--muted);
        line-height: 1.95;
      }

      .site-footer {
        margin-top: 22px;
        padding: 20px 24px 28px;
        color: var(--soft);
        font-size: 12px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .article-shell {
        width: min(calc(100% - 40px), 980px);
        margin: 0 auto;
        position: relative;
        z-index: 1;
      }

      .back-link {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin: 12px 0 0;
        color: var(--muted);
        font-size: 13px;
        letter-spacing: 0.08em;
        text-transform: uppercase;
      }

      .article-header {
        margin-top: 18px;
        padding: 34px 30px 28px;
        border-radius: var(--radius);
        border: 1px solid var(--line);
        position: relative;
        overflow: hidden;
      }

      .article-header h1 {
        max-width: 14ch;
        font-size: clamp(38px, 5vw, 62px);
      }

      .article-meta {
        display: flex;
        flex-wrap: wrap;
        gap: 14px;
        color: var(--soft);
        font-size: 11px;
        letter-spacing: 0.16em;
        text-transform: uppercase;
      }

      .article-desc {
        margin: 20px 0 0;
        max-width: 43rem;
        color: var(--text-dim);
        font-size: 19px;
        line-height: 1.9;
      }

      .article-main {
        margin-top: 18px;
        padding: 30px;
      }

      .prose {
        width: min(100%, var(--article-width));
        font-size: 18px;
        line-height: 1.95;
      }

      .prose > *:first-child { margin-top: 0; }
      .prose h2,
      .prose h3 {
        margin-top: 2.4em;
        margin-bottom: 0.7em;
        font-family: "Iowan Old Style", "Palatino Linotype", "Book Antiqua", Georgia, serif;
        letter-spacing: -0.04em;
        line-height: 1.14;
        color: var(--paper);
      }
      .prose h2 { font-size: 34px; }
      .prose h3 { font-size: 27px; }
      .prose p,
      .prose li { color: var(--text-dim); }
      .prose ul,
      .prose ol { padding-left: 1.35em; }
      .prose a {
        color: var(--accent);
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.2em;
      }
      .prose strong { color: #ffffff; }
      .prose blockquote {
        margin: 2em 0;
        padding: 0 0 0 18px;
        border-left: 2px solid var(--accent-2);
        color: #cddcf7;
      }
      .prose code {
        font-family: "SFMono-Regular", ui-monospace, Menlo, monospace;
        padding: 0.16em 0.42em;
        border: 1px solid rgba(111, 168, 255, 0.18);
        border-radius: 8px;
        background: rgba(111, 168, 255, 0.08);
        font-size: 0.86em;
      }
      .prose pre {
        padding: 18px 20px;
        border-radius: 18px;
        overflow-x: auto;
        border: 1px solid var(--line);
        background: rgba(7, 14, 25, 0.88);
        box-shadow: inset 0 1px 0 rgba(255,255,255,0.03);
      }
      .prose pre code {
        padding: 0;
        background: transparent;
        border: none;
      }
      .prose hr {
        border: none;
        border-top: 1px solid var(--line);
        margin: 2.4em 0;
      }
      .prose table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.95em;
      }
      .prose th,
      .prose td {
        padding: 12px 14px;
        border-bottom: 1px solid var(--line);
        text-align: left;
      }
      .prose th {
        color: var(--paper);
        font-weight: 600;
      }

      @media (max-width: 900px) {
        .home-intro,
        .section-head,
        .post-row {
          grid-template-columns: 1fr;
        }
        .post-row { gap: 14px; }
      }

      @media (max-width: 640px) {
        .shell,
        .article-shell {
          width: min(calc(100% - 24px), var(--page-width));
        }
        .site-nav {
          flex-direction: column;
          align-items: flex-start;
        }
        .hero-panel,
        .article-header,
        .article-main,
        .about-block,
        .site-footer {
          padding-left: 18px;
          padding-right: 18px;
        }
        .intro-side { padding: 0; background: transparent; border: none; box-shadow: none; }
        .home-intro h1 { font-size: 44px; }
        .post-row { padding: 18px; }
        .post-row h3 { font-size: 24px; }
        .prose { font-size: 17px; }
      }
    </style>
  </head>
  <body>
    <slot />
  </body>
</html>
