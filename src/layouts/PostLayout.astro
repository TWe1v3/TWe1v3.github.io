---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
---
<BaseLayout title={`${title} - TWe1v3`} description={description ?? title}>
  <div class="article-shell">
    <nav class="site-nav">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>TWe1v3</span>
      </a>
      <div class="nav-note">Notes on systems, security and operator craft.</div>
    </nav>

    <div class="divider"></div>
    <a class="back-link" href="/">← Back to index</a>

    <header class="article-header">
      <div class="article-meta">
        <span>{date}</span>
        <span>Essay</span>
      </div>
      <h1>{title}</h1>
      {description && <p class="article-desc">{description}</p>}
      {tags.length > 0 && (
        <div class="tags">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <main class="article-main">
      <article class="prose">
        <slot />
      </article>
    </main>

    <footer class="site-footer">Curated in public · Drafted in private knowledge workflows</footer>
  </div>
</BaseLayout>
