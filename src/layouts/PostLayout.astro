---
import BaseLayout from './BaseLayout.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
---
<BaseLayout title={`${title} - TWe1v3`} description={description ?? title}>
  <div class="article-shell">
    <nav class="site-nav">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>TWe1v3</span>
      </a>
      <div class="nav-note">Thoughts on security, automation, systems and operator craft.</div>
    </nav>

    <a class="back-link" href="/">← 返回首页</a>

    <header class="article-header">
      <div class="article-meta">
        <span>{date}</span>
        <span>Public note</span>
      </div>
      <h1>{title}</h1>
      {description && <p class="article-desc">{description}</p>}
      {tags.length > 0 && (
        <div class="tags" style="margin-top: 22px;">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <main class="article-card">
      <article class="prose">
        <slot />
      </article>
    </main>

    <footer class="site-footer">Published on GitHub Pages · Curated from a private research workflow</footer>
  </div>
</BaseLayout>
