---
import BaseLayout from './BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';

interface Props {
  title: string;
  description?: string;
  date: string;
  tags?: string[];
}

const { title, description, date, tags = [] } = Astro.props;
---
<BaseLayout title={`${title} - TWe1v3`} description={description ?? title}>
  <div class="article-shell">
    <SiteHeader note="Long-form essays, field notes, and security/operator writing." />
    <a class="back-link" href="/">← Back to index</a>

    <header class="article-hero animate-rise">
      <div class="article-meta">
        <span>{date}</span>
        <span>Essay</span>
        <span>Field Notes</span>
      </div>
      <h1 class="article-title">{title}</h1>
      {description && <p class="article-lede">{description}</p>}
      {tags.length > 0 && (
        <div class="tag-row">
          {tags.map((tag) => (
            <span class="tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <main class="prose-card animate-rise">
      <article class="prose">
        <slot />
      </article>
    </main>

    <SiteFooter label="Curated in public. Built for long-form technical reading." />
  </div>
</BaseLayout>
