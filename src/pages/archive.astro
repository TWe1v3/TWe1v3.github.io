---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getArchiveGroups } from '../lib/posts';

const grouped = getArchiveGroups();
---
<BaseLayout title="Archive - TWe1v3" description="按时间浏览公开写作。">
  <div class="page-shell">
    <SiteHeader note="Browse the publication by month, then jump into the essays that still matter." />

    <section class="page-hero animate-rise">
      <div class="eyebrow">Archive</div>
      <h1 class="page-title">按时间回看公开输出，但不要再像数据库列表那样读它们。</h1>
      <p class="page-lede">把文章按月份聚拢，方便持续回看站点的判断演进，而不只是浏览一串散乱列表。</p>
    </section>

    <section class="archive-grid animate-rise">
      {grouped.map(([month, items]) => (
        <section class="archive-group">
          <div class="archive-month">{month}</div>
          {items.map((post) => (
            <a class="archive-entry" href={post.href}>
              <div class="story-meta">{post.date}</div>
              <h3>{post.title}</h3>
              <p>{post.desc}</p>
              <div class="tag-row">
                {post.tags.map((tag) => <span class="tag">{tag}</span>)}
              </div>
            </a>
          ))}
        </section>
      ))}
    </section>

    <SiteFooter label="Archive of public writing." />
  </div>
</BaseLayout>
