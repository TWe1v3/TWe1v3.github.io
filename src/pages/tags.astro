---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import SiteFooter from '../components/SiteFooter.astro';
import { getTagGroups } from '../lib/posts';

const tags = getTagGroups();
---
<BaseLayout title="Tags - TWe1v3" description="按主题浏览公开写作。">
  <div class="page-shell">
    <SiteHeader note="Theme clusters extracted from the archive so topics can become durable entry points." />

    <section class="page-hero animate-rise">
      <div class="eyebrow">Tags</div>
      <h1 class="page-title">按主题而不是按时间浏览，让标签逐步长成真正的长期入口。</h1>
      <p class="page-lede">这些标签会逐步变成长期研究的公开入口。现在先从已有文章里自动聚合，后面再扩展成真正的专题页。</p>
    </section>

    <section class="page-grid animate-rise">
      {tags.map(([tag, items]) => (
        <section class="panel">
          <div class="card-eyebrow">{items.length} entries</div>
          <h2>{tag}</h2>
          <div class="tag-row">
            <span class="tag">{tag}</span>
          </div>
          <div class="cluster-grid">
            {items.slice(0, 3).map((post) => (
              <a class="compact-card" href={post.href}>
                <div class="story-meta">{post.date}</div>
                <h3>{post.title}</h3>
                <p>{post.desc}</p>
              </a>
            ))}
          </div>
        </section>
      ))}
    </section>

    <SiteFooter label="Theme index." />
  </div>
</BaseLayout>
