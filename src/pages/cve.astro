---
import BaseLayout from '../layouts/BaseLayout.astro';

const watchTargets = [
  { name: 'Zammad', note: '当前首个实操目标，适合沿 IDOR / ticket ownership / query injection 做深入分析。', status: 'active' },
  { name: 'Rocket.Chat', note: '业务系统攻击面丰富，适合权限边界与注入类 variant analysis。', status: 'watch' },
  { name: 'Jenkins Plugins', note: '插件生态大，适合做系列化 patch diff 和 permission check 研究。', status: 'watch' }
];

const latest = [
  { title: '建立 CVE 挖掘工作流', meta: 'Workflow', desc: '目标池、评分卡、漏洞笔记模板和 disclosure 路径已经开始落地，后续这里会接入更真实的 watchboard 数据。' },
  { title: 'Zammad 进入首轮深挖', meta: 'Current target', desc: '已完成代码热点初扫与 GHSL 线索收集，下一步围绕 ticket 与授权边界继续下钻。' }
];
---
<BaseLayout title="CVE Monitor - TWe1v3" description="CVE 目标与研究信号看板。">
  <div class="page-shell">
    <nav class="site-nav">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>TWe1v3</span>
      </a>
      <div class="nav-links">
        <a class="nav-link" href="/archive">Archive</a>
        <a class="nav-link" href="/tags">Tags</a>
        <a class="nav-link" href="/updates">Updates</a>
        <a class="nav-link" href="/about">About</a>
      </div>
    </nav>

    <div class="divider"></div>

    <section class="page-panel">
      <div class="page-kicker">CVE watchboard</div>
      <h1 class="page-title">把漏洞挖掘从想法，推成持续运行的研究线。</h1>
      <p class="page-lede">这里后面会逐步承载值得深挖的项目、近期安全信号、patch diff 候选、watchlist 和我自己的简短判断。当前版本先把结构立起来。</p>
      <div class="page-tag-row">
        <span class="page-tag">CVE</span>
        <span class="page-tag">Patch Diff</span>
        <span class="page-tag">Variant Analysis</span>
      </div>
    </section>

    <div class="page-grid">
      <section class="mini-card-grid">
        {latest.map((item) => (
          <div class="mini-card">
            <div class="meta-kicker">{item.meta}</div>
            <h3>{item.title}</h3>
            <p>{item.desc}</p>
          </div>
        ))}
      </section>

      <section class="list-panel">
        <div class="about-block">
          <div class="section-kicker">Watch targets</div>
          <p class="page-copy">先聚焦少量高价值目标，形成长期可复用的方法，而不是把目标池摊得太散。</p>
        </div>
        {watchTargets.map((item) => (
          <div class="list-item">
            <div class="list-meta">{item.status}</div>
            <div>
              <h3>{item.name}</h3>
              <p>{item.note}</p>
            </div>
            <div class="post-link-mark">•</div>
          </div>
        ))}
      </section>
    </div>

    <footer class="site-footer">TWe1v3 · CVE hunting board</footer>
  </div>
</BaseLayout>
