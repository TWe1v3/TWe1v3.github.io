---
import BaseLayout from '../layouts/BaseLayout.astro';

const postModules = import.meta.glob('./posts/*.{astro,md}', { eager: true });
const posts = Object.values(postModules)
  .map((mod) => mod.postMeta ?? mod.frontmatter)
  .filter(Boolean)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---
<BaseLayout title="TWe1v3" description="能力沉淀、个人思考、自动化实验与安全研究。">
  <div class="shell">
    <nav class="site-nav">
      <a class="brand" href="/">
        <span class="brand-mark"></span>
        <span>TWe1v3</span>
      </a>
      <div class="nav-note">A research-flavoured notebook for systems, security and operator craft.</div>
    </nav>

    <div class="divider"></div>

    <header class="home-intro">
      <section class="hero-panel">
        <div class="kicker">Public writing</div>
        <h1>把研究感、系统感和作品感，写成一套能被看见的长期资产。</h1>
        <p class="lede">这里不是流水账，也不是为了凑更新频率。它更像一个持续公开的研究工作台：筛选值得沉淀的判断，把安全、自动化、AI 工作流与 operator discipline 写成真正可读、可复用、可代表水准的东西。</p>
        <div class="pill-row">
          <span class="pill">Security research</span>
          <span class="pill">Operator systems</span>
          <span class="pill">Automation craft</span>
        </div>
      </section>

      <aside class="editorial-rail">
        <div class="rail-kicker">Editorial note</div>
        <p class="rail-lede">这不是一个靠“信息量”取胜的站，而是一个靠筛选、结构和判断感建立长期气质的公开写作空间。</p>

        <div class="rail-block">
          <span class="rail-label">What gets published</span>
          <p>原始素材先在私域里验证、裁剪、补证据链。只有逻辑够稳、表达够清楚、能代表长期方向的内容，才会进入这里。</p>
        </div>

        <div class="rail-block">
          <span class="rail-label">Current focus</span>
          <p>AI agent 边界、自动化系统、安全研究、个人工作台设计，以及那些真正影响执行质量的约束和方法。</p>
        </div>

        <div class="rail-rule">Less dashboard, more publication.</div>
      </aside>
    </header>

    <section class="section">
      <div class="section-head">
        <div>
          <div class="section-kicker">Latest archive</div>
          <h2>Recent writing</h2>
        </div>
        <p class="section-copy">整体风格改成偏深色、编辑感、研究型的阅读界面：保留技术博客的克制，但把层次、版式、卡片感和文章页的阅读体验拉到更像一个成熟的个人研究站。</p>
      </div>

      <div class="post-list">
        {posts.map((post) => (
          <a class="post-row" href={post.href}>
            <div class="post-date">{post.date}</div>
            <div>
              <h3>{post.title}</h3>
              <p>{post.desc}</p>
              {post.tags?.length ? (
                <div class="pill-row">
                  {post.tags.map((tag) => <span class="pill">{tag}</span>)}
                </div>
              ) : null}
            </div>
            <div class="post-link-mark">↗</div>
          </a>
        ))}
      </div>
    </section>

    <section class="about-block">
      <div class="section-kicker">Why this exists</div>
      <p>我希望这个 blog 最后呈现出来的气质，不像“把博客系统搭起来了”，而像“一个长期做判断和做系统的人，把值得公开的部分慢慢写出来”。所以后面我会继续推进：更好的文章页节奏、更稳的视觉语言、更强的成果页和专题页。</p>
    </section>

    <footer class="site-footer">TWe1v3 · Taste, structure, and operator-grade clarity</footer>
  </div>
</BaseLayout>
